// Waypoint data model — implements docs/architecture/data-model.md.
// Keep in sync with packages/shared/src/entities.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts, not here.
}

enum AuthProvider {
  google
}

enum EventKind {
  hard
  soft
}

enum EventStatus {
  planned
  done
  skipped
}

enum EventSource {
  manual
  gmail
  maybe_shelf
  integration
}

enum BookingType {
  flight
  hotel
  restaurant
  train
  activity
  other
}

enum BookingSource {
  manual
  gmail
}

enum MembershipRole {
  admin
  peer
}

enum DocumentType {
  passport
  insurance
  visa
  other
}

enum TripNoteCategory {
  wifi
  note
}

enum ChangeAction {
  create
  update
  move
  delete
  status
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  avatarColor String   @default("#E9A63C")
  createdAt   DateTime @default(now())

  authIdentities     AuthIdentity[]
  sessions           Session[]
  memberships        Membership[]
  tripsCreated       Trip[]
  maybeItems         MaybeItem[]
  changes            Change[]
  calendarEventLinks CalendarEventLink[]
}

// Provider identity + that provider's OAuth material, one per (user, provider). ADR-0020.
model AuthIdentity {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  refreshTokenEnc   String? // encrypted at rest (ADR-0015)
  scopes            String[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Rotating refresh-token store (ADR-0020).
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trip {
  id               String   @id @default(cuid())
  name             String
  destination      String
  icon             String? // glyph-only trip identity (ADR-0038); UI falls back to DEFAULT_TRIP_ICON
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  timezone         String   @default("UTC")
  currency         String?
  dailyBudgetMinor Int?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedBy        String

  creator     User         @relation(fields: [createdBy], references: [id])
  memberships Membership[]
  events      Event[]
  bookings    Booking[]
  documents   Document[]
  maybeItems  MaybeItem[]
  tripNotes   TripNote[]
  changes     Change[]

  @@index([createdBy])
}

model Membership {
  id                  String         @id @default(cuid())
  tripId              String
  userId              String
  role                MembershipRole @default(peer)
  calendarSyncEnabled Boolean        @default(false)
  joinedAt            DateTime       @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
}

model Event {
  id        String      @id @default(cuid())
  tripId    String
  date      DateTime    @db.Date
  endDate   DateTime?   @db.Date // non-null = multi-day ambient span (ADR-0018)
  title     String
  icon      String?
  kind      EventKind
  startsAt  DateTime? // UTC instant
  endsAt    DateTime?
  location  String?
  placeId   String?
  status    EventStatus @default(planned)
  bookingId String?
  sortOrder Int         @default(0)
  source    EventSource @default(manual)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  updatedBy String

  trip          Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  booking       Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  calendarLinks CalendarEventLink[]

  @@index([tripId, date])
}

model Booking {
  id               String        @id @default(cuid())
  tripId           String
  type             BookingType
  title            String
  confirmationCode String?
  provider         String?
  address          String?
  placeId          String?
  startsAt         DateTime? // a hotel across nights is ONE booking with a range (ADR-0018)
  endsAt           DateTime?
  details          Json?
  source           BookingSource @default(manual)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  updatedBy        String

  trip   Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events Event[]

  @@index([tripId])
}

// Idempotency map for one-way calendar push, per member per event (ADR-0020).
model CalendarEventLink {
  id                    String   @id @default(cuid())
  eventId               String
  userId                String
  googleCalendarEventId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model Document {
  id          String       @id @default(cuid())
  tripId      String
  type        DocumentType
  title       String
  fileRef     String // reference to a server-side-encrypted blob (ADR-0015)
  mimeType    String
  sizeBytes   Int
  ownerUserId String? // null = group doc
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  updatedBy   String

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model MaybeItem {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  icon      String?
  placeId   String?
  createdBy String
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// WiFi codes, notes — the practical layer's small stuff (ADR-0018).
model TripNote {
  id        String           @id @default(cuid())
  tripId    String
  category  TripNoteCategory
  label     String
  value     String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  updatedBy String

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// The sync/undo/feed substrate; seq is a strictly-increasing cursor (ADR-0019).
model Change {
  id          String       @id @default(cuid())
  seq         BigInt       @default(autoincrement())
  tripId      String
  actorUserId String
  entityType  String
  entityId    String
  action      ChangeAction
  before      Json?
  after       Json?
  createdAt   DateTime     @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([tripId, seq])
}
