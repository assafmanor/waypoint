// Waypoint data model — implements docs/architecture/data-model.md.
// Keep in sync with packages/shared/src/entities.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts, not here.
}

enum AuthProvider {
  google
}

enum EventKind {
  hard
  soft
}

enum EventStatus {
  planned
  done
  skipped
}

enum EventSource {
  manual
  gmail
  maybe_shelf
  integration
}

enum BookingType {
  flight
  hotel
  restaurant
  train
  activity
  other
}

// Canonical semantic type of a timeline item (ADR-0038). The `icon` glyph is
// only its badge; BookingType and map-pin colours derive from this.
enum EventCategory {
  transport
  food
  lodging
  sightseeing
  nature
  activity
  shopping
  services
  other
}

enum BookingSource {
  manual
  gmail
}

enum MembershipRole {
  admin
  peer
}

enum DocumentType {
  passport
  insurance
  visa
  other
}

enum ChangeAction {
  create
  update
  move
  delete
  status
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  avatarColor String   @default("#E9A63C")
  createdAt   DateTime @default(now())

  authIdentities     AuthIdentity[]
  sessions           Session[]
  memberships        Membership[]
  tripsCreated       Trip[]
  maybeItems         MaybeItem[]
  changes            Change[]
  calendarEventLinks CalendarEventLink[]
  tripBlocks         TripBlock[]
}

// Provider identity + that provider's OAuth material, one per (user, provider). ADR-0020.
model AuthIdentity {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  refreshTokenEnc   String? // encrypted at rest (ADR-0015)
  scopes            String[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Rotating refresh-token store (ADR-0020).
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trip {
  id               String   @id @default(cuid())
  name             String
  destination      String
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  timezone         String   @default("UTC")
  currency         String?
  dailyBudgetMinor Int?
  icon             String?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedBy        String

  creator     User         @relation(fields: [createdBy], references: [id])
  memberships Membership[]
  events      Event[]
  bookings    Booking[]
  documents   Document[]
  maybeItems  MaybeItem[]
  places      Place[]
  changes     Change[]
  invite      Invite?
  blocks      TripBlock[]

  @@index([createdBy])
}

// One durable, revocable invite per trip (ADR-0067). The short random `code` is
// both the public handle in /join/<code> and the grant itself — join resolves
// code → row → tripId (no separate token). Rotating mints a fresh code in place,
// so the old one stops resolving. Validity is until the trip ends (checked live
// against Trip.endDate) or an admin rotates; no fixed timer.
model Invite {
  id        String   @id @default(cuid())
  tripId    String   @unique
  code      String   @unique
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// A user barred from rejoining a trip via its invite (ADR-0067). Written when an
// admin removes another member (not on a self-leave); checked at join. Gates
// joining only — all access stays gated by Membership.
model TripBlock {
  tripId    String
  userId    String
  blockedBy String
  blockedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tripId, userId])
  @@index([userId])
}

model Membership {
  id                  String         @id @default(cuid())
  tripId              String
  userId              String
  role                MembershipRole @default(peer)
  calendarSyncEnabled Boolean        @default(false)
  joinedAt            DateTime       @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  // getMe / listForUser filter by userId alone; the composite unique above leads
  // with tripId, so those scan without this (backend-review B-09).
  @@index([userId])
}

model Event {
  id        String         @id @default(cuid())
  tripId    String
  date      DateTime       @db.Date
  endDate   DateTime?      @db.Date // non-null = multi-day ambient span (ADR-0018)
  title     String
  icon      String?
  category  EventCategory?
  kind      EventKind
  startsAt  DateTime? // UTC instant
  endsAt    DateTime?
  placeId   String? // authoritative only for unlinked events; cleared when bookingId is set (ADR-0048)
  status    EventStatus    @default(planned)
  bookingId String?        @unique // strict 1:1 with Booking (ADR-0047)
  sortOrder Int            @default(0)
  source    EventSource    @default(manual)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  updatedBy String

  trip          Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  booking       Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  place         Place?              @relation("EventPlace", fields: [placeId], references: [id], onDelete: SetNull)
  calendarLinks CalendarEventLink[]

  @@index([tripId, date])
}

model Booking {
  id               String        @id @default(cuid())
  tripId           String
  type             BookingType
  title            String
  confirmationCode String?
  provider         String?
  placeId          String? // single-place types (hotel/restaurant/…); mutually exclusive with from/to
  fromPlaceId      String? // transport origin (map-pin/nav target of the linked Event) — ADR-0048
  toPlaceId        String? // transport destination — ADR-0048
  details          Json?
  source           BookingSource @default(manual)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  updatedBy        String

  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  event     Event? // strict 1:1 (Event.bookingId @unique, ADR-0047)
  place     Place? @relation("BookingPlace", fields: [placeId], references: [id], onDelete: SetNull)
  fromPlace Place? @relation("BookingFromPlace", fields: [fromPlaceId], references: [id], onDelete: SetNull)
  toPlace   Place? @relation("BookingToPlace", fields: [toPlaceId], references: [id], onDelete: SetNull)

  @@index([tripId])
}

// Trip-scoped location registry (ADR-0048). Name-only rows are valid ("Place-lite");
// googlePlaceId/lat/lng/timezone/rating are filled in later by the Google Places
// picker on a pick (ADR-0108). The row *is* the enrichment cache — dedup-before-spend
// keys on @@unique([tripId, googlePlaceId]) so a place is enriched at most once per trip
// (Postgres treats NULLs as distinct, so many name-only rows still coexist).
model Place {
  id               String   @id @default(cuid())
  tripId           String
  googlePlaceId    String?
  name             String
  address          String?
  lat              Float?
  lng              Float?
  timezone         String? // IANA zone, resolved once server-side via geo-tz (ADR-0107/0108)
  rating           Float? // Google aggregate rating 0–5 (ADR-0109 §9)
  userRatingsTotal Int? // count behind `rating`
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedBy        String

  trip         Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events       Event[]     @relation("EventPlace")
  bookings     Booking[]   @relation("BookingPlace")
  bookingsFrom Booking[]   @relation("BookingFromPlace")
  bookingsTo   Booking[]   @relation("BookingToPlace")
  maybeItems   MaybeItem[] @relation("MaybeItemPlace")

  @@unique([tripId, googlePlaceId])
  @@index([tripId])
}

// Idempotency map for one-way calendar push, per member per event (ADR-0020).
model CalendarEventLink {
  id                    String   @id @default(cuid())
  eventId               String
  userId                String
  googleCalendarEventId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model Document {
  id          String       @id @default(cuid())
  tripId      String
  type        DocumentType
  title       String
  fileRef     String // reference to a server-side-encrypted blob (ADR-0015)
  mimeType    String
  sizeBytes   Int
  ownerUserId String? // null = group doc
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  updatedBy   String

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model MaybeItem {
  id        String         @id @default(cuid())
  tripId    String
  title     String
  icon      String?
  category  EventCategory?
  placeId   String?
  createdBy String
  consumed  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  updatedBy String

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  place Place? @relation("MaybeItemPlace", fields: [placeId], references: [id], onDelete: SetNull)

  @@index([tripId])
}

// The sync/undo/feed substrate; seq is a strictly-increasing cursor (ADR-0019).
model Change {
  id          String       @id @default(cuid())
  seq         BigInt       @default(autoincrement())
  tripId      String
  actorUserId String
  entityType  String
  entityId    String
  action      ChangeAction
  before      Json?
  after       Json?
  createdAt   DateTime     @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([tripId, seq])
}
