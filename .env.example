# Copy to `.env` at the repo root (backend/.env also works and wins).
# Production values live in the Railway dashboard (deployment.md), never in a file.

# Matches docker-compose.yml for local dev.
DATABASE_URL=postgresql://waypoint:waypoint@localhost:5432/waypoint

# Signs access JWTs and invite tokens (ADR-0020). Generate: openssl rand -base64 32
JWT_SECRET=

# Encrypts Google refresh tokens at rest (ADR-0020); must be base64 decoding to
# exactly 32 bytes. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Google OAuth client (prerequisites-checklist.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Document encryption at rest (ADR-0015). Must decode to exactly 32 bytes.
# Generate: openssl rand -base64 32
DOC_ENCRYPTION_KEY=

# Railway Storage Bucket (S3-compatible, ADR-0031). Leave unset locally — documents
# fall back to ./backend/storage/documents (gitignored).
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Dev-only. NEVER set these in production. ────────────────────────────────
# CORS origin for the :5173 → :3000 dev gap; prod is single-origin (ADR-0020).
FRONTEND_URL=http://localhost:5173
# Uncomment to bypass Google login locally.
# DEV_AUTH=1
