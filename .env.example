# Copy to `.env` at the repo root (CLAUDE.md quickstart). backend/.env also
# works and wins when both exist. Placeholders only — never commit real values.
# Production values are set in the Railway dashboard, not in a file
# (docs/architecture/deployment.md).

# Postgres — matches docker-compose.yml for local dev.
DATABASE_URL=postgresql://waypoint:waypoint@localhost:5432/waypoint

# Signs access JWTs and invite tokens (ADR-0020). Generate: openssl rand -base64 32
JWT_SECRET=

# Encrypts Google refresh tokens at rest, AES-256-GCM (ADR-0020).
# MUST be base64 decoding to exactly 32 bytes. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Google OAuth client (docs/engineering/prerequisites-checklist.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Dev-only. NEVER set these in production. ────────────────────────────────
# CORS origin for the Vite dev server gap (:5173 → :3000); prod is
# single-origin (ADR-0020) and needs no CORS.
FRONTEND_URL=http://localhost:5173
# Uncomment to bypass Google login locally (dev principal). A security hole
# anywhere else.
# DEV_AUTH=1
